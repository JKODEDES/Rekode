<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DocGov · Sistema de Gestión Documental</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0D2340;--navy-mid:#1A3A5C;--blue:#1565C0;--blue-light:#1976D2;
  --accent:#2196F3;--accent-glow:#42A5F5;--white:#FFFFFF;--offwhite:#F7F9FC;
  --gray-50:#F8FAFC;--gray-100:#EEF2F7;--gray-200:#E2E8F0;--gray-300:#CBD5E1;
  --gray-400:#94A3B8;--gray-500:#64748B;--gray-700:#334155;--gray-900:#0F172A;
  --success:#00897B;--warning:#F57C00;--danger:#C62828;
  --shadow-sm:0 1px 3px rgba(13,35,64,.08);--shadow-md:0 4px 16px rgba(13,35,64,.12);
  --shadow-lg:0 12px 40px rgba(13,35,64,.18);--shadow-xl:0 24px 64px rgba(13,35,64,.24);
  --radius:10px;--radius-lg:16px;--tr:all .3s cubic-bezier(.4,0,.2,1);
}
body{font-family:'Inter',sans-serif;background:var(--white);color:var(--gray-900);overflow-x:hidden}
button{cursor:pointer;border:none;outline:none;font-family:'Inter',sans-serif}
input,textarea,select{font-family:'Inter',sans-serif;outline:none}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--gray-100)}
::-webkit-scrollbar-thumb{background:var(--blue-light);border-radius:3px}
.hidden{display:none!important}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes splashFill{from{width:0}to{width:100%}}
@keyframes pulse{0%,100%{box-shadow:0 8px 32px rgba(21,101,192,.3)}50%{box-shadow:0 8px 48px rgba(21,101,192,.5)}}
@keyframes modalIn{from{opacity:0;transform:scale(.96) translateY(16px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes cardIn{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes pageIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── SPLASH ── */
#splash{position:fixed;inset:0;background:var(--white);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .6s ease,visibility .6s ease}
#splash.hide{opacity:0;visibility:hidden;pointer-events:none}
.splash-emblem{width:72px;height:72px;margin-bottom:24px;background:linear-gradient(135deg,var(--navy) 0%,var(--blue) 100%);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 32px rgba(21,101,192,.3);animation:pulse 2s infinite}
.splash-emblem svg{width:36px;height:36px;fill:white}
.splash-logo{font-size:42px;font-weight:800;letter-spacing:-2px;color:var(--navy);margin-bottom:6px}
.splash-logo span{color:var(--blue)}
.splash-sub{font-size:12px;color:var(--gray-400);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:48px}
.splash-bar-bg{width:200px;height:2px;background:var(--gray-200);border-radius:2px;overflow:hidden}
.splash-bar-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--accent));border-radius:2px;animation:splashFill 2.2s ease forwards}

/* ── AUTH ── */
.auth-bg{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,var(--offwhite) 0%,var(--white) 50%,#EBF2FF 100%);position:relative;overflow:hidden;padding:24px}
.auth-bg::before{content:'';position:absolute;top:-200px;right:-200px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(33,150,243,.06) 0%,transparent 70%)}
.auth-bg::after{content:'';position:absolute;bottom:-200px;left:-200px;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(13,35,64,.04) 0%,transparent 70%)}
.auth-card{background:var(--white);border-radius:20px;box-shadow:0 2px 4px rgba(0,0,0,.04),0 8px 32px rgba(13,35,64,.1),0 32px 80px rgba(13,35,64,.08);width:100%;max-width:500px;overflow:hidden;position:relative;z-index:1;animation:cardIn .5s cubic-bezier(.4,0,.2,1)}
.auth-header{background:linear-gradient(135deg,var(--navy) 0%,var(--navy-mid) 100%);padding:28px 36px 24px;color:white}
.auth-header-logo{font-size:22px;font-weight:800;letter-spacing:-1px;margin-bottom:4px}
.auth-header-logo span{color:var(--accent-glow)}
.auth-header-sub{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;opacity:.55;margin-bottom:12px}
.auth-header-title{font-size:15px;font-weight:500;opacity:.85}
.auth-body{padding:32px 36px}
.field{margin-bottom:18px}
.field label{display:block;font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--gray-500);margin-bottom:7px}
.field-wrap{position:relative}
.field-wrap .ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--gray-400);pointer-events:none;display:flex;align-items:center;justify-content:center}
.field-wrap .ico svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
.field input,.field select,.field textarea{width:100%;padding:12px 14px 12px 40px;border:1.5px solid var(--gray-200);border-radius:var(--radius);font-size:14px;color:var(--gray-900);background:var(--gray-50);transition:var(--tr)}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--blue);background:white;box-shadow:0 0 0 3px rgba(21,101,192,.1)}
.field select{appearance:none}
.field textarea{padding-left:14px;resize:vertical;min-height:80px;padding-top:12px}
.field-hint{font-size:11px;color:var(--gray-400);margin-top:5px;line-height:1.5}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:12px 22px;border-radius:var(--radius);font-size:14px;font-weight:600;transition:var(--tr);letter-spacing:.3px;white-space:nowrap}
.btn-primary{background:linear-gradient(135deg,var(--blue) 0%,var(--blue-light) 100%);color:white;box-shadow:0 4px 16px rgba(21,101,192,.28);width:100%}
.btn-primary:hover{background:linear-gradient(135deg,var(--navy-mid) 0%,var(--blue) 100%);box-shadow:0 6px 24px rgba(21,101,192,.4);transform:translateY(-1px)}
.btn-primary:active{transform:translateY(0)}
.btn-secondary{background:white;color:var(--navy);border:1.5px solid var(--gray-200)}
.btn-secondary:hover{border-color:var(--blue);color:var(--blue);background:var(--gray-50)}
.btn-danger{background:var(--danger);color:white}
.btn-danger:hover{background:#B71C1C}
.btn-success{background:var(--success);color:white}
.btn-sm{padding:8px 14px;font-size:12px}
.btn-icon{padding:7px;border-radius:8px;background:transparent;color:var(--gray-500)}
.btn-icon:hover{background:var(--gray-100);color:var(--navy)}
.btn-icon svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}
.auth-switch{text-align:center;margin-top:18px;font-size:13px;color:var(--gray-500)}
.auth-switch a{color:var(--blue);font-weight:600;cursor:pointer}
.auth-switch a:hover{color:var(--navy)}
.divider{height:1px;background:var(--gray-100);margin:18px 0}
.alert{padding:11px 15px;border-radius:10px;font-size:13px;margin-bottom:14px;display:flex;align-items:center;gap:9px}
.alert svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.alert-error{background:#FFEBEE;color:#C62828;border:1px solid #FFCDD2}
.alert-success{background:#E8F5E9;color:#2E7D32;border:1px solid #C8E6C9}
.alert-info{background:#E3F2FD;color:#1565C0;border:1px solid #BBDEFB}
.alert-warning{background:#FFF8E1;color:#E65100;border:1px solid #FFE082}

/* ── STEP BAR ── */
.step-bar{padding:20px 28px 0}
.step-track{display:flex;align-items:center;position:relative}
.step-track::before{content:'';position:absolute;top:18px;left:0;right:0;height:2px;background:var(--gray-200);z-index:0}
.step-progress{position:absolute;top:18px;left:0;height:2px;background:linear-gradient(90deg,var(--blue),var(--accent));z-index:1;transition:width .6s cubic-bezier(.4,0,.2,1)}
.step-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:5px;position:relative;z-index:2}
.step-circle{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;transition:var(--tr);border:2px solid var(--gray-200);background:white;color:var(--gray-400)}
.step-circle.active{border-color:var(--blue);background:var(--blue);color:white;box-shadow:0 4px 12px rgba(21,101,192,.3)}
.step-circle.done{border-color:var(--success);background:var(--success);color:white}
.step-circle svg{width:16px;height:16px;stroke:white;fill:none;stroke-width:2.5}
.step-label{font-size:10px;font-weight:600;color:var(--gray-400);letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
.step-label.active{color:var(--blue)}
.step-label.done{color:var(--success)}

/* ── APP LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:260px;min-height:100vh;background:linear-gradient(180deg,var(--navy) 0%,var(--navy-mid) 100%);display:flex;flex-direction:column;position:fixed;left:0;top:0;bottom:0;z-index:100}
.sidebar-logo{padding:22px 22px 18px;border-bottom:1px solid rgba(255,255,255,.06)}
.sidebar-logo-text{font-size:19px;font-weight:800;letter-spacing:-1px;color:white}
.sidebar-logo-text span{color:var(--accent-glow)}
.sidebar-logo-sub{font-size:10px;color:rgba(255,255,255,.38);letter-spacing:2px;text-transform:uppercase;margin-top:2px}
.sidebar-user{padding:14px 18px;margin:12px;border-radius:12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.06)}
.sidebar-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--blue));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;margin-bottom:8px}
.sidebar-name{font-size:13px;font-weight:600;color:white;line-height:1.3}
.sidebar-role{font-size:11px;color:rgba(255,255,255,.4);margin-top:2px}
.sidebar-nav{flex:1;padding:6px 10px;overflow-y:auto}
.nav-section{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.28);padding:14px 12px 7px}
.nav-item{display:flex;align-items:center;gap:11px;padding:10px 13px;border-radius:10px;color:rgba(255,255,255,.62);font-size:13px;font-weight:500;cursor:pointer;transition:var(--tr);margin-bottom:2px;position:relative}
.nav-item:hover{background:rgba(255,255,255,.08);color:white}
.nav-item.active{background:rgba(33,150,243,.18);color:var(--accent-glow);font-weight:600}
.nav-item.active::before{content:'';position:absolute;left:0;top:6px;bottom:6px;width:3px;background:var(--accent-glow);border-radius:0 3px 3px 0}
.nav-item svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.nav-badge{margin-left:auto;background:var(--accent);color:white;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px}
.sidebar-footer{padding:14px;border-top:1px solid rgba(255,255,255,.06)}
.sidebar-logout{display:flex;align-items:center;gap:10px;padding:10px 13px;border-radius:10px;color:rgba(255,255,255,.48);font-size:13px;font-weight:500;cursor:pointer;transition:var(--tr);width:100%}
.sidebar-logout:hover{background:rgba(198,40,40,.15);color:#EF9A9A}
.sidebar-logout svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2}
.main{margin-left:260px;min-height:100vh;background:var(--offwhite);flex:1}
.topbar{height:62px;background:white;border-bottom:1px solid var(--gray-200);display:flex;align-items:center;padding:0 28px;gap:14px;position:sticky;top:0;z-index:50}
.topbar-title{font-size:16px;font-weight:700;color:var(--navy);flex:1}
.topbar-actions{display:flex;align-items:center;gap:10px}
.topbar-avatar{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--accent));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;cursor:pointer;flex-shrink:0}
.page{padding:26px 28px;animation:pageIn .4s ease}
.card{background:white;border-radius:var(--radius-lg);border:1px solid var(--gray-200);box-shadow:var(--shadow-sm);margin-bottom:20px}
.card-header{padding:18px 22px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:15px;font-weight:700;color:var(--navy)}
.card-subtitle{font-size:12px;color:var(--gray-400);margin-top:2px}
.card-body{padding:22px}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.stat-card{background:white;border-radius:var(--radius-lg);border:1px solid var(--gray-200);padding:18px 20px;box-shadow:var(--shadow-sm);transition:var(--tr)}
.stat-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.stat-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;margin-bottom:12px}
.stat-icon svg{width:19px;height:19px;stroke:currentColor;fill:none;stroke-width:2}
.stat-value{font-size:28px;font-weight:800;color:var(--navy);line-height:1;margin-bottom:3px}
.stat-label{font-size:12px;color:var(--gray-400);font-weight:500}
.search-bar{display:flex;align-items:center;gap:9px;background:white;border:1.5px solid var(--gray-200);border-radius:10px;padding:0 14px;transition:var(--tr)}
.search-bar:focus-within{border-color:var(--blue);box-shadow:0 0 0 3px rgba(21,101,192,.1)}
.search-bar svg{width:15px;height:15px;stroke:var(--gray-400);fill:none;stroke-width:2;flex-shrink:0}
.search-bar input{border:none;background:none;padding:10px 0;font-size:13px;color:var(--gray-900);flex:1}
.search-bar input::placeholder{color:var(--gray-400)}
.toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.toolbar-right{margin-left:auto;display:flex;gap:8px}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th{background:var(--gray-50);padding:11px 15px;text-align:left;font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--gray-500);border-bottom:1px solid var(--gray-200);white-space:nowrap}
td{padding:12px 15px;font-size:13px;color:var(--gray-700);border-bottom:1px solid var(--gray-100)}
tr:hover td{background:var(--gray-50)}
tr:last-child td{border-bottom:none}
.badge{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px}
.badge-active{background:#E8F5E9;color:#2E7D32}
.badge-inactive{background:var(--gray-100);color:var(--gray-500)}
.badge-admin{background:#E3F2FD;color:var(--blue)}
.badge-user{background:#F3E5F5;color:#6A1B9A}
.badge-info{background:#E3F2FD;color:var(--blue)}
.file-item{display:flex;align-items:center;gap:13px;padding:13px 16px;border-radius:10px;border:1px solid var(--gray-200);background:white;margin-bottom:9px;transition:var(--tr)}
.file-item:hover{border-color:var(--blue-light);box-shadow:var(--shadow-sm)}
.file-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:20px;background:var(--gray-50)}
.file-info{flex:1;min-width:0}
.file-name{font-size:13px;font-weight:600;color:var(--navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.file-meta{font-size:11px;color:var(--gray-400);margin-top:3px}
.file-note-chip{font-size:11px;color:var(--blue);background:#EBF3FE;padding:3px 9px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;margin-top:5px}
.file-actions{display:flex;gap:5px;flex-shrink:0}
.note-item{border-radius:12px;padding:15px 17px;margin-bottom:11px;border:1px solid var(--gray-200);background:white;transition:var(--tr)}
.note-item:hover{border-color:var(--gray-300);box-shadow:var(--shadow-sm)}
.note-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:9px}
.note-title{font-size:14px;font-weight:700;color:var(--navy)}
.note-date{font-size:11px;color:var(--gray-400)}
.note-body{font-size:13px;color:var(--gray-700);line-height:1.6}
.note-files{display:flex;flex-wrap:wrap;gap:7px;margin-top:11px}
.note-file-chip{font-size:11px;background:var(--gray-100);color:var(--gray-700);padding:3px 9px;border-radius:20px;display:flex;align-items:center;gap:4px;border:1px solid var(--gray-200)}
.tag{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.5px;padding:2px 8px;border-radius:20px;text-transform:uppercase;margin-right:5px}
.tag-urgent{background:#FFF3E0;color:#E65100}
.tag-info{background:#E3F2FD;color:#1565C0}
.tag-done{background:#E8F5E9;color:#2E7D32}
.drop-zone{border:2px dashed var(--gray-300);border-radius:var(--radius-lg);padding:36px;text-align:center;cursor:pointer;transition:var(--tr);background:var(--gray-50)}
.drop-zone:hover,.drop-zone.drag{border-color:var(--blue);background:#EBF3FE}
.drop-zone-icon{font-size:40px;margin-bottom:14px}
.drop-zone-title{font-size:15px;font-weight:600;color:var(--navy);margin-bottom:5px}
.drop-zone-sub{font-size:13px;color:var(--gray-400)}
.empty-state{text-align:center;padding:52px 36px;color:var(--gray-400)}
.empty-state .empty-icon{font-size:48px;margin-bottom:14px}
.empty-state h3{font-size:15px;font-weight:600;color:var(--gray-500);margin-bottom:5px}
.empty-state p{font-size:13px}
.modal-overlay{position:fixed;inset:0;background:rgba(13,35,64,.5);backdrop-filter:blur(6px);z-index:1000;display:flex;align-items:center;justify-content:center;padding:22px;animation:fadeIn .2s ease}
.modal{background:white;border-radius:20px;box-shadow:var(--shadow-xl);width:100%;max-width:520px;animation:modalIn .25s cubic-bezier(.4,0,.2,1);max-height:90vh;overflow-y:auto}
.modal-header{padding:22px 26px 18px;border-bottom:1px solid var(--gray-100);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-size:16px;font-weight:700;color:var(--navy);display:flex;align-items:center;gap:8px}
.modal-body{padding:22px 26px}
.modal-footer{padding:14px 26px 22px;display:flex;gap:10px;justify-content:flex-end}
.admin-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(198,40,40,.1);border:1px solid rgba(198,40,40,.2);border-radius:8px;padding:6px 12px;font-size:12px;font-weight:700;color:var(--danger)}
.admin-badge svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.grid-3{display:grid;grid-template-columns:130px 1fr;gap:14px}
.summary-row{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--gray-100)}
.summary-key{font-size:12px;color:var(--gray-400);font-weight:600}
.summary-val{font-size:13px;color:var(--navy);font-weight:500}
.info-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.info-box{background:var(--gray-50);border-radius:10px;padding:13px 15px;border:1px solid var(--gray-200)}
.info-box-label{font-size:10px;color:var(--gray-400);font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
.info-box-val{font-size:13px;font-weight:600;color:var(--navy)}
.spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .7s linear infinite;display:inline-block}
.profile-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
</style>
</head>
<body>

<!-- SPLASH -->
<div id="splash">
  <div class="splash-emblem">
    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
  </div>
  <div class="splash-logo">Doc<span>Gov</span></div>
  <div class="splash-sub">Sistema Documental · República de Colombia</div>
  <div class="splash-bar-bg" style="width:200px;height:2px;background:var(--gray-200);border-radius:2px;overflow:hidden">
    <div class="splash-bar-fill" style="height:100%;background:linear-gradient(90deg,var(--blue),var(--accent));border-radius:2px;animation:splashFill 2.2s ease forwards"></div>
  </div>
</div>

<!-- LOGIN -->
<div id="screen-login" class="auth-bg hidden">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-header-logo">Doc<span>Gov</span></div>
      <div class="auth-header-sub">República de Colombia · Regis